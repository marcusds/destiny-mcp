{
  "name": "d2-mcp",
  "version": "2.0.0",
  "description": "Comprehensive MCP server for the Bungie.net Destiny 2 API — read + authenticated write actions, clan management, and a local manifest cache",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "d2-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:websocket": "node dist/index.js websocket",
    "start:stdio": "node dist/index.js stdio",
    "auth": "node dist/index.js auth",
    "dev": "tsx src/index.ts",
    "dev:auth": "tsx src/index.ts auth",
    "dev:websocket": "tsx src/index.ts websocket",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "mcp",
    "bungie",
    "destiny",
    "destiny2",
    "api",
    "model-context-protocol",
    "ai",
    "claude",
    "oauth"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "ws": "^8.18.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  }
}
