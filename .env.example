# --- Required for all tools -------------------------------------------------
# API key from https://www.bungie.net/en/Application
BUNGIE_API_KEY=

# --- Required only for authenticated tools (write actions, "me" lookups) -----
# OAuth client id + secret from the same Bungie application page.
# Use a "Confidential" app type to get a client secret.
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=

# Must EXACTLY match the redirect URL registered on the Bungie application.
# The built-in `auth` command listens on this URL to capture the auth code.
BUNGIE_REDIRECT_URI=https://localhost:7777/callback
BUNGIE_OAUTH_PORT=7777

# Where tokens and the cached manifest are stored. Defaults to ~/.d2-mcp
# D2_MCP_DATA_DIR=
